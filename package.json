{
  "name": "vscode-db-browser",
  "displayName": "DB Sidebar Explorer",
  "description": "Browse and edit MySQL and SQLite databases from a VS Code sidebar tree and editor tabs.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbExplorer",
          "title": "Databases",
          "icon": "media/database.svg"
        }
      ]
    },
    "views": {
      "dbExplorer": [
        {
          "id": "dbExplorer.home",
          "name": "Database Explorer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dbExplorer.home",
        "contents": "Browse and edit your databases in a dedicated editor tab.\n[Open Database Explorer](command:dbExplorer.open)\n[Add Connection](command:dbExplorer.addConnection)"
      }
    ],
    "commands": [
      {
        "command": "dbExplorer.open",
        "title": "DB Explorer: Open",
        "icon": "$(window)"
      },
      {
        "command": "dbExplorer.addConnection",
        "title": "DB Explorer: Add Connection",
        "icon": "$(add)"
      },
      {
        "command": "dbExplorer.refresh",
        "title": "DB Explorer: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbExplorer.open",
          "when": "view == dbExplorer.home",
          "group": "navigation@0"
        },
        {
          "command": "dbExplorer.addConnection",
          "when": "view == dbExplorer.home",
          "group": "navigation@1"
        },
        {
          "command": "dbExplorer.refresh",
          "when": "view == dbExplorer.home",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build:webview": "node esbuild.js",
    "build:webview:watch": "node esbuild.js --watch",
    "build": "npm run compile && npm run build:webview",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run build",
    "test": "npm run compile && mocha \"out/test/**/*.test.js\""
  },
  "dependencies": {
    "mysql2": "^3.14.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.21.5",
    "mocha": "^11.1.0",
    "tabulator-tables": "^6.3.0",
    "typescript": "^5.8.2"
  }
}
